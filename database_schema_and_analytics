--9 RANK DOCTORS BY TOTAL REVENUE GENERATED
SELECT d.doctor_id, d.doctor_name, SUM(b.amount)  AS total_revenue, 
RANK() OVER (ORDER BY SUM(b.amount) DESC ) AS doctor_rank_by_revenue
FROM doctors AS d
JOIN appointments AS a
USING(doctor_id)
JOIN billing AS b
USING(appointment_id)
GROUP BY d.doctor_id, d.doctor_name
ORDER BY doctor_rank_by_revenue ;

--10 FOR EACH PATIENT, SHOW THEIR MOST RECENT APPOINTMENT
