--11 IDENTIFY PATIENTS WHOSE INSURANCE COVER LESS THAN 70% OF THEIR BILL
SELECT
  p.patient_id,
  p.first_name,
  p.last_name,
  b.amount,
  TRUNC(b.insurance_covered::decimal/b.amount, 2) AS percentage_covered,
  b.insurance_covered,
  p.insurance_provider
FROM patients AS p
JOIN appointments AS a
USING(patient_id)
JOIN billing AS b
USING(appointment_id)
WHERE b.insurance_covered< 0.7* b.amount
ORDER BY percentage_covered DESC;

