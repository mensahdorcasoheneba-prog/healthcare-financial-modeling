--14 Which age group has the highest incidence of hypertension (I10)?
SELECT 
CASE
  WHEN EXTRACT(YEAR FROM AGE(p.date_of_birth)) BETWEEN 0 AND 17
      THEN 'Children'
  WHEN EXTRACT(YEAR FROM AGE(p.date_of_birth)) BETWEEN 18 AND 35
      THEN 'Young Adult'
  WHEN EXTRACT(YEAR FROM AGE(p.date_of_birth)) BETWEEN 36 AND 50
      THEN ' Senior Adult'
  WHEN EXTRACT(YEAR FROM AGE(p.date_of_birth)) BETWEEN 51 AND 80
      THEN 'Elder'
  ELSE 'Senior Citizens'
END AS  age_group ,
  COUNT(d.diagnosis_code) AS hypertension_count
FROM patients AS p
JOIN appointments AS a
USING(patient_id)
JOIN diagnosis AS d
USING(appointment_id)
WHERE d.diagnosis_code='I10'
GROUP BY age_group
ORDER BY hypertension_count DESC
--LIMIT 1
  ;
--15 Which insurance provider covers the highest average amount?
SELECT p.insurance_provider, AVG(b.insurance_covered) average_amount_covered
FROM  patients AS p
JOIN appointments AS a
USING(patient_id)
JOIN billing AS b
USING(appointment_id)
GROUP BY p.insurance_provider
ORDER BY average_amount_covered DESC
LIMIT 1
;

--16 Determine peak days of the week for appointments.
SELECT CASE
   EXTRACT(DOW FROM a.appointment_date) 
  WHEN 0 THEN 'Sunday'
  WHEN 1 THEN 'Monday'
  WHEN 2 THEN 'Tuesday'
  WHEN 3 THEN 'Wednesday'
  WHEN 4 THEN 'Thursday'
  WHEN 5 THEN 'Friday'
  WHEN 6 THEN 'Saturday'
END AS day_of_week,
COUNT (a.appointment_id) AS number_of_appointments
FROM appointments AS a
GROUP BY day_of_week
ORDER BY number_of_appointments DESC;

