--3.  GET ALL COMPLETED APPOINTMENTS IN FEBRUARY 2024 (*2025)
SELECT appointment_id, status, appointment_date
FROM appointments
WHERE status = 'Completed'
AND appointment_date >='2025-02-01'
AND appointment_date< '2025-03-01'
;

--4 SHOW EACH DOCTOR AND HOW MANY APPOINTMENTS THEY COMPLETED
SELECT d.doctor_name, COUNT(a.appointment_id) AS number_of_appointments_completed
FROM doctors AS d
JOIN appointments AS a
USING(doctor_id)
WHERE a.status='Completed'
GROUP BY d.doctor_name
ORDER BY number_of_appointments_completed DESC;

--5 FIND THE MOST COMMON DIAGNOSIS IN THE DATABASE
WITH common_diagnosis AS(
  SELECT diagnosis_code, COUNT(diagnosis) AS most_common_diagnosis
  FROM diagnosis
  GROUP BY diagnosis_code
)
SELECT diagnosis_code, most_common_diagnosis
FROM common_diagnosis
WHERE most_common_diagnosis= (
SELECT MAX(most_common_diagnosis)
FROM common_diagnosis 
  );
-- 5 WITH LIMIT
SELECT diagnosis_code, COUNT(diagnosis_code) AS most_common_diagnosis
FROM diagnosis
GROUP BY diagnosis_code
ORDER BY most_common_diagnosis DESC
LIMIT 1;

--  6 List the total billing amount per patient
SELECT p.patient_id, CONCAT(p.first_name, ' ', p.last_name) AS patient_full_name, 
  SUM(b.amount) AS total_billing_amount
FROM patients AS p
JOIN appointments AS a
USING(patient_id)
JOIN billing AS b
USING(appointment_id)
GROUP BY p.patient_id, patient_full_name
ORDER BY total_billing_amount DESC;

--7 Which clinic location has the highest number of appointments?
SELECT d.clinic_location, COUNT(a.appointment_id) AS number_of_appointments
FROM appointments AS a
JOIN doctors AS d
USING (doctor_id)
GROUP BY d.clinic_location
ORDER BY number_of_appointments DESC
LIMIT 1;

--8 Identify patients who have more than one diagnosis in 2024
SELECT p.patient_id, CONCAT(p.first_name, '  ', p.last_name) AS patient_full_name,
COUNT(diagnosis_id) AS number_of_diagnosis
FROM patients AS p 
JOIN appointments AS a
USING(patient_id)
JOIN diagnosis AS d
USING(appointment_id)
WHERE EXTRACT(YEAR FROM a.appointment_date) =2024
GROUP BY p.patient_id, patient_full_name
HAVING COUNT(d.diagnosis_id)>1
ORDER BY number_of_diagnosis
;
--8 with CTE
WITH patient_diagnosis_count AS(
  SELECT p.patient_id, CONCAT(p.first_name, '  ', p.last_name) AS patient_full_name, 
  COUNT(diagnosis_id) AS number_of_diagnosis
  FROM patients AS p 
  JOIN appointments AS a
  USING(patient_id)
  JOIN diagnosis AS d
  USING(appointment_id)
  WHERE  EXTRACT(YEAR FROM a.appointment_date )=2024
  GROUP BY p.patient_id, patient_full_name
)

SELECT * 
FROM patient_diagnosis_count
WHERE number_of_diagnosis>1
ORDER BY number_of_diagnosis;

