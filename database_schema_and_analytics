--FIND DOCTORS WITH APPOINTMENT RATE ABOVE AVERAGE
WITH appointment_count AS(
  SELECT d.doctor_id, d.doctor_name AS doctor_name, COUNT (a.appointment_id) AS number_of_appointments
  FROM doctors AS d
  JOIN appointments AS a
  USING(doctor_id)
  GROUP BY d.doctor_name, d.doctor_id
)
  ,
avg_appointment AS(
  SELECT AVG(number_of_appointments) OVER() AS average_number_of_appointments
  FROM appointment_count
)
SELECT ac.doctor_name, ac.doctor_id, ac.number_of_appointments
FROM appointment_count AS ac, avg_appointment AS aa
WHERE ac.number_of_appointments> aa.average_number_of_appointments
GROUP BY ac.doctor_id, ac.doctor_name, ac.number_of_appointments
ORDER BY ac.number_of_appointments;

--For each doctor, show each patient and the next scheduled patient visit?

SELECT

    a.doctor_id,

    d.doctor_name,

    a.patient_id,

    p.first_name || ' ' || p.last_name AS patient_name,

    a.appointment_date,

    LEAD(p.first_name || ' ' || p.last_name)

        OVER (PARTITION BY a.doctor_id ORDER BY a.appointment_date) AS next_patient

FROM appointments a

JOIN doctors d ON a.doctor_id = d.doctor_id

JOIN patients p ON a.patient_id = p.patient_id

--Return each appointment with its diagnosis description and bill amount

SELECT a.appointment_id, a.appointment_date, d.diagnosis_code, d.diagnosis_description, b.amount AS bill_amount

FROM appointments AS a

JOIN diagnoses AS d ON d.appointment_id = a.appointment_id

JOIN billing AS b ON b.appointment_id = d.appointment_id;

--Count how many diagnosis each appointment has

SELECT appointment_id, COUNT(*) AS diagnosis_count

FROM diagnoses

GROUP BY appointment_id

ORDER BY diagnosis_count DESC;
